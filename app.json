{
  "expo": {
    "name": "AI私塾",
    "slug": "ai-private-tutor",
    "version": "1.0.22",
    "orientation": "portrait",
    "icon": "https://miaoda-edit-image.cdn.bcebos.com/bmp8n1fqz9c1/IMG-bn1iwhhz5hq8.jpg",
    "splash": {
      "backgroundColor": "#2C5F8A",
      "resizeMode": "contain",
      "image": "https://miaoda-edit-image.cdn.bcebos.com/bmp8n1fqz9c1/IMG-bmqw7k52677k.jpg"
    },
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1",
      "bundleIdentifier": "com.miaoda.appbmp8n1fqz9c1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "https://miaoda-edit-image.cdn.bcebos.com/bmp8n1fqz9c1/IMG-bn1iwhhz5hq8.jpg",
        "backgroundColor": "#2C5F8A"
      },
      "predictiveBackGestureEnabled": false,
      "versionCode": 3,
      "package": "com.miaoda.appbmp8n1fqz9c1",
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-sqlite",
      "expo-font",
      "expo-system-ui",
      "expo-document-picker",
      "expo-sharing",
      "expo-web-browser",
      "expo-secure-store",
      "@react-native-async-storage/expo-with-async-storage",
      "expo-file-system",
      "expo-splash-screen",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2C5F8A",
          "iosDisplayInForeground": true
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "允许 $(PRODUCT_NAME) 使用麦克风进行口语录音评测"
        }
      ]
    ],
    "router": {
      "root": "src"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c79ebba9-bdf1-4416-ac5e-8a92216060ea"
      }
    },
    "owner": "3266"
  }
}
